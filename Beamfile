aurora {
  version = "1"
  default = "check"
}

beam "fmt" {
  description = "Format Rust code"
  inputs = ["crates/**/*.rs"]
  run { commands = ["cargo fmt --all"] }
}

beam "clippy" {
  description = "Lint with clippy"
  depends_on = ["fmt"]
  inputs = ["crates/**/*.rs"]
  run { commands = ["cargo clippy --workspace --all-targets -- -D warnings"] }
}

beam "test" {
  description = "Run all tests"
  depends_on = ["fmt"]
  inputs = ["crates/**/*.rs"]
  run { commands = ["cargo test --workspace"] }
}

beam "build" {
  description = "Build release binary"
  inputs = ["crates/**/*.rs"]
  run { commands = ["cargo build --release"] }
}

beam "check" {
  description = "Format + lint + test"
  depends_on = ["clippy", "test"]
}

beam "bench" {
  description = "Benchmark aurora against make, just and task"
  depends_on  = ["build"]
  run { commands = ["./benchmarks/run.sh", "./benchmarks/cache-correctness.sh"] }
}

beam "install" {
  description = "Install the aurora binary globally from source"
  depends_on = ["check"]
  run { commands = ["cargo install --path crates/aurora --force"] }
}
